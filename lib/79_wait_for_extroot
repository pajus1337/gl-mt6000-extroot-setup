#!/bin/sh
# Wait for USB extroot device before mount_root runs.
# GL-MT6000 hardware: USB controller enumerates ~4 s after preinit starts.
# Without this delay mount_root misses the extroot UUID and falls back to
# the internal eMMC overlay.

wait_for_extroot() {
    # During preinit the ROM fstab is empty so we cannot check fstab here.
    # Wait unconditionally for /dev/sda1; on GL-MT6000 USB enumerates ~4s into
    # boot, well before mount_root at ~8s, so this normally exits in 1 iteration.
    local i=0
    while [ $i -lt 15 ]; do
        if [ -b /dev/sda1 ]; then
            sleep 1   # Extra second for blkid to read UUID reliably
            # ext4 may not be loaded yet when mount_root runs; load it now so the
            # extroot mount attempt doesn't fail with "unknown filesystem".
            modprobe ext4 2>/dev/null || insmod /lib/modules/*/ext4.ko 2>/dev/null || true
            return 0
        fi
        sleep 1
        i=$(( i + 1 ))
    done
    return 0  # Don't abort boot if USB never appears
}

boot_hook_add preinit_main wait_for_extroot
